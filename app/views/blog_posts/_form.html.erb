
<%= form_with model: blog_post do |f| %>
    <% if f.object.errors.any? %>
        <div>
            <h4 style="color: red;">Please fix the following errors:</h4>
            <ul style="color: red;">
                <% f.object.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                <% end %>
            </ul>
        </div>
    <% end %>
    <div>
        <%= f.label :title %>
        <%= f.text_field :title %>
    </div>
    <div>
        <%= f.label :body %>
        <%= f.text_area :body %>
    </div>
    <%= f.button %>
<% end %>